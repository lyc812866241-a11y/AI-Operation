{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git commit --no-verify -m ':*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -c ':*)",
      "Bash(bash .ai-operation/scripts/sync-rules.sh)",
      "Bash(npm install:*)",
      "Bash(omm --version)",
      "Bash(omm setup:*)",
      "Bash(omm config:*)",
      "Bash(omm write:*)",
      "Bash(omm view:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-dangerous.sh",
            "timeout": 10,
            "statusMessage": "Checking for dangerous commands..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-context.sh",
            "timeout": 5,
            "statusMessage": "Checking cognitive gate..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/governance-capture.sh",
            "timeout": 5,
            "statusMessage": "Recording operation..."
          }
        ]
      }
    ]
  }
}
