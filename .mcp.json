{
  "mcpServers": {
    "project_architect": {
      "command": "REPLACE_WITH_YOUR_VENV_PYTHON_PATH",
      "args": [
        "-u",
        ".ai-operation/mcp_server/server.py"
      ],
      "alwaysAllow": [
        "aio__force_architect_save",
        "aio__force_architect_read",
        "aio__force_garbage_collection",
        "aio__force_project_bootstrap_write",
        "aio__force_architect_report",
        "aio__force_test_runner",
        "aio__force_taskspec_submit",
        "aio__force_taskspec_approve",
        "aio__force_fast_track",
        "aio__inventory_append",
        "aio__inventory_consolidate",
        "aio__force_architect_save_confirm",
        "aio__detail_read",
        "aio__detail_list",
        "aio__confirm_read",
        "aio__load_experience",
        "aio__bypass_violation",
        "aio__rule_monitor",
        "aio__extract_skill",
        "aio__scan_codebase",
        "aio__audit_project_map"
      ]
    },
    "markitdown": {
      "command": "markitdown-mcp",
      "alwaysAllow": [
        "convert_to_markdown"
      ]
    }
  }
}
